          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Avg squash batch size (commands/squash call)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr":
              "rate(dragonfly_pipeline_squash_commands_total[$__rate_interval]) / clamp_min(rate(dragonfly_pipeline_squash_calls_total[$__rate_interval]), 1)",
          "legendFormat": "avg batch",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
